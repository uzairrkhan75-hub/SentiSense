# Flask
# Set to "production" on the live server -- this enforces that SECRET_KEY
# and JWT_SECRET_KEY are actually set, and disables Flask's debug mode.
FLASK_ENV=development
SECRET_KEY=change-this-secret-key
JWT_SECRET_KEY=change-this-jwt-secret-key

# MongoDB (use a MongoDB Atlas URI in production)
MONGO_URI=mongodb://localhost:27017/sentisense

# CORS (comma separated origins). In production, set this to your frontend's
# domain, e.g. https://yourdomain.com
CORS_ORIGINS=http://localhost:5173

# Google Sign-In (OAuth client ID from Google Cloud Console)
GOOGLE_CLIENT_ID=
